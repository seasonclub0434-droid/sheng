.page {
  position: relative;
  width: 750rpx;
  height: 100vh;
  overflow: hidden;
  color: #352f2a;
  background: #caa36f;
  font-family: "Hannotate SC", "Kaiti SC", "PingFang SC", sans-serif;
}

.rope-canvas {
  position: absolute;
  z-index: 1;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 100vh;
}

.floating-note {
  position: absolute;
  left: 50%;
  bottom: 212rpx;
  z-index: 12;
  box-sizing: border-box;
  max-width: 520rpx;
  padding: 22rpx 28rpx;
  color: #6b5d50;
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
  background: rgba(248, 241, 225, 0.9);
  border: 2rpx solid rgba(97, 78, 56, 0.14);
  border-radius: 16rpx 14rpx 18rpx 12rpx;
  transform: translateX(-50%) rotate(-1deg);
}

.modal-mask {
  position: absolute;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  box-sizing: border-box;
  padding: 40rpx 36rpx 60rpx;
  background: rgba(58, 49, 40, 0.12);
}

.paper-card {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  max-width: 860rpx;
  padding: 40rpx 36rpx 32rpx;
  background:
    linear-gradient(98deg, rgba(111, 88, 60, 0.05), transparent 34%),
    #fbf3dc;
  border: 2rpx solid rgba(92, 70, 46, 0.22);
  border-radius: 16rpx 14rpx 18rpx 12rpx;
  box-shadow: 0 20rpx 56rpx rgba(65, 52, 38, 0.08);
}

.card-title {
  color: #3a3129;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-meta {
  margin-top: 8rpx;
  color: #8a7b69;
  font-size: 24rpx;
}

.note-input,
.resolve-input {
  width: 100%;
  box-sizing: border-box;
  color: #3b332c;
  font-size: 32rpx;
  line-height: 1.6;
  background: rgba(255, 251, 240, 0.55);
  border: 2rpx solid rgba(93, 70, 44, 0.15);
  border-radius: 14rpx;
}

.note-input {
  height: 336rpx;
  margin-top: 30rpx;
  padding: 24rpx;
}

.resolve-input {
  height: 172rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.input-placeholder {
  color: #b4a58e;
}

.detail-content {
  min-height: 136rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  color: #4b4036;
  font-size: 30rpx;
  line-height: 1.65;
  white-space: pre-wrap;
  background: rgba(255, 250, 239, 0.46);
  border: 2rpx solid rgba(93, 70, 44, 0.11);
  border-radius: 14rpx;
}

.resolution-lines {
  margin-top: 24rpx;
  color: #6b5c4f;
  font-size: 26rpx;
  line-height: 1.55;
}

.line-note {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  background: rgba(239, 228, 207, 0.62);
  border-left: 6rpx solid rgba(157, 86, 66, 0.48);
  border-radius: 10rpx;
}

.line-note-right {
  margin-left: 52rpx;
  border-left-color: rgba(82, 122, 126, 0.44);
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 32rpx;
}

.text-button,
.ink-button {
  min-width: 144rpx;
  box-sizing: border-box;
  margin-left: 20rpx;
  padding: 22rpx 28rpx;
  font-size: 28rpx;
  border-radius: 14rpx;
}

.text-button {
  color: #7b6b5c;
}

.ink-button {
  color: #f9f1df;
  background: #6e5a47;
  border: 2rpx solid rgba(48, 35, 24, 0.22);
}

.notebook-card {
  max-height: 78vh;
}

.notebook-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notebook-search {
  width: 240rpx;
  height: 68rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: rgba(255, 250, 233, 0.72);
}

.notebook-list {
  max-height: 720rpx;
  margin-top: 24rpx;
}

.notebook-item {
  margin-bottom: 18rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 249, 231, 0.55);
}

.notebook-item-title,
.notebook-item-meta,
.notebook-item-content {
  display: block;
}

.notebook-item-title {
  font-weight: 700;
}

.notebook-item-meta {
  margin-top: 6rpx;
  color: #8a7b69;
  font-size: 24rpx;
}

.notebook-item-content {
  margin-top: 12rpx;
  color: #4b4036;
  font-size: 26rpx;
  line-height: 1.5;
}
