.login-gate {
  display: block;
  padding: 0;
  overflow: hidden;
  perspective: 1200rpx;
}

.login-cabinet-frame {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 760rpx;
  max-width: none;
  height: auto;
  transform: translateX(-50%);
  transform-origin: 50% 58%;
  will-change: transform, opacity, filter;
}

.login-cabinet-image {
  width: 100%;
  height: 100%;
}

.image-login-gate.opening .login-cabinet-frame {
  animation: loginCabinetPushOpen 620ms cubic-bezier(0.2, 0.72, 0.22, 1) both;
}

.image-login-gate.opening .login-enter-action {
  pointer-events: none;
}

.image-login-gate.opening .login-enter-glow {
  animation: loginGlowCollapse 620ms ease both;
}

@keyframes loginCabinetPushOpen {
  0% {
    opacity: 1;
    filter: blur(0);
    transform: translateX(-50%) translateY(0) scale(1) rotateX(0);
  }

  55% {
    opacity: 0.94;
    filter: blur(1rpx);
    transform: translateX(-50%) translateY(-12rpx) scale(0.96) rotateX(5deg);
  }

  100% {
    opacity: 0;
    filter: blur(5rpx);
    transform: translateX(-50%) translateY(36rpx) scale(0.84) rotateX(13deg);
  }
}

@keyframes loginGlowCollapse {
  0% {
    opacity: 0.9;
    transform: translate(-50%, -50%) scale(1);
  }

  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.58);
  }
}

