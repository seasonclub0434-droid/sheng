.page {
  position: relative;
  width: 750rpx;
  height: 100vh;
  overflow: hidden;
  color: #352f2a;
  background:
    radial-gradient(circle at 18% 12%, rgba(110, 83, 52, 0.11), transparent 28%),
    radial-gradient(circle at 82% 86%, rgba(75, 57, 38, 0.09), transparent 30%),
    #a99b7c;
  font-family: "Hannotate SC", "Kaiti SC", "PingFang SC", sans-serif;
}

.page::after {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  content: "";
  opacity: 0.38;
  background-image:
    linear-gradient(rgba(76, 63, 48, 0.055) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(76, 63, 48, 0.04) 2rpx, transparent 2rpx);
  background-size: 36rpx 44rpx, 58rpx 62rpx;
}

.rope-canvas {
  position: absolute;
  z-index: 2;
  top: 0;
  left: 0;
  width: 750rpx;
  height: 100vh;
}

.login-gate,
.home-page,
.rope-add-page {
  position: absolute;
  z-index: 2;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
}

.login-gate {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 20rpx;
}

.login-cabinet-frame {
  position: relative;
  width: 690rpx;
  max-width: 690rpx;
  height: 1180rpx;
}

.login-cabinet-image {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 36rpx 56rpx rgba(48, 33, 20, 0.28));
}

.login-enter-action {
  position: absolute;
  z-index: 5;
  left: 50%;
  top: 59.4%;
  display: grid;
  width: 248rpx;
  height: 248rpx;
  padding: 0;
  place-items: center;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: transparent;
  border: 0;
  overflow: visible;
}

.login-enter-action::after {
  border: 0;
}

.login-enter-glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 256rpx;
  height: 256rpx;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 221, 128, 0.44);
  background:
    radial-gradient(ellipse at 50% 48%, rgba(255, 224, 138, 0.15), transparent 50%),
    radial-gradient(ellipse at 60% 60%, rgba(255, 206, 98, 0.12), transparent 30%);
  box-shadow:
    0 0 0 2rpx rgba(81, 38, 10, 0.1),
    0 0 28rpx rgba(255, 207, 96, 0.28),
    inset 0 0 24rpx rgba(255, 229, 158, 0.16);
  opacity: 0.68;
  transform-origin: center;
  transform: translate(-50%, -50%);
  animation: loginGlowBreath 2.8s ease-in-out infinite;
}

.login-enter-glow::after {
  position: absolute;
  top: 22%;
  left: 12%;
  width: 58%;
  height: 25%;
  content: "";
  border-radius: 50%;
  opacity: 0.52;
  background:
    radial-gradient(ellipse at 45% 50%, rgba(255, 239, 176, 0.54), transparent 58%),
    linear-gradient(90deg, rgba(255, 209, 112, 0), rgba(255, 211, 116, 0.34), rgba(255, 209, 112, 0));
  filter: blur(8rpx);
  transform: rotate(-16deg);
}

@keyframes loginGlowBreath {
  0%,
  100% {
    opacity: 0.56;
    transform: translate(-50%, -50%) scale(0.96);
  }

  50% {
    opacity: 0.96;
    transform: translate(-50%, -50%) scale(1.025);
  }
}

.home-page,
.rope-add-page {
  margin: 0;
  width: 750rpx;
  max-width: none;
  border-radius: 0;
  left: 50%;
  right: auto;
  transform: translateX(-50%);
  background:
    linear-gradient(92deg, rgba(255, 239, 191, 0.17), transparent 18%, rgba(90, 58, 30, 0.08) 62%, transparent 82%),
    linear-gradient(rgba(71, 52, 34, 0.04) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(71, 52, 34, 0.035) 2rpx, transparent 2rpx),
    #caa36f;
  background-size: auto, 36rpx 42rpx, 56rpx 62rpx;
  box-shadow:
    inset 0 0 76rpx rgba(84, 56, 32, 0.16),
    0 36rpx 80rpx rgba(43, 32, 22, 0.18);
  overflow: hidden;
}

.home-title-image {
  position: absolute;
  z-index: 4;
  top: 0;
  left: 50%;
  width: 340rpx;
  height: 164rpx;
  transform: translateX(-50%);
}

.rope-shelf {
  position: absolute;
  z-index: 2;
  top: 168rpx;
  left: 50%;
  width: 638rpx;
  bottom: 154rpx;
  transform: translateX(-50%);
  overflow: hidden;
}

.cabinet-stack {
  position: relative;
  width: 100%;
  min-height: 100%;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
  border-radius: 14rpx;
  background:
    linear-gradient(90deg, rgba(48, 27, 12, 0.55), transparent 5%, transparent 95%, rgba(48, 27, 12, 0.55)),
    #8e551f;
  box-shadow:
    inset 0 0 0 2rpx rgba(45, 23, 10, 0.55),
    inset 0 0 48rpx rgba(45, 24, 11, 0.44);
}

.cabinet-top,
.cabinet-bottom {
  display: block;
  height: 34rpx;
  margin: 0 0 0;
  border-radius: 16rpx;
  background:
    linear-gradient(180deg, #c57a26 0%, #8d4d16 52%, #5f2f0e 100%);
  box-shadow:
    inset 0 4rpx 8rpx rgba(255, 210, 116, 0.25),
    inset 0 -12rpx 20rpx rgba(42, 22, 10, 0.38),
    0 4rpx 14rpx rgba(31, 19, 11, 0.45);
}

.cabinet-bottom {
  margin-top: 0;
}

.cabinet-row {
  position: relative;
  height: 270rpx;
  overflow: hidden;
  transform: none;
}

.cabinet-back {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 20rpx;
  bottom: 44rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(90deg, rgba(48, 26, 12, 0.2), transparent 22%, rgba(52, 28, 14, 0.2) 50%, transparent 76%, rgba(48, 26, 12, 0.2)),
    linear-gradient(rgba(68, 37, 16, 0.1) 2rpx, transparent 2rpx),
    #9a6028;
  background-size: auto, 28rpx 36rpx;
  box-shadow: inset 0 20rpx 40rpx rgba(38, 21, 10, 0.42);
}

.cabinet-back::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 24rpx;
  content: "";
  transform: translateX(-50%);
  background: linear-gradient(90deg, rgba(42, 21, 9, 0.18), rgba(218, 144, 57, 0.42), rgba(42, 21, 9, 0.2));
  box-shadow: 0 0 20rpx rgba(35, 19, 9, 0.35);
}

.cabinet-slots {
  position: relative;
  z-index: 2;
  top: auto;
  right: auto;
  left: auto;
  min-height: 182rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 56rpx;
}

.cabinet-slot {
  position: relative;
  min-height: 192rpx;
}

.empty-slot {
  opacity: 0.1;
}

.cabinet-front {
  position: absolute;
  z-index: 3;
  left: 0;
  right: 0;
  bottom: 0;
  height: 60rpx;
  border-radius: 8rpx;
  background:
    linear-gradient(180deg, rgba(255, 187, 74, 0.48), transparent 21%),
    linear-gradient(180deg, #bd721e 0%, #8a4a12 46%, #5a2d0c 100%);
  box-shadow:
    inset 0 4rpx 10rpx rgba(255, 213, 122, 0.2),
    inset 0 -16rpx 22rpx rgba(43, 22, 8, 0.38),
    0 -2rpx 14rpx rgba(38, 20, 9, 0.4);
}

.rope-tile {
  overflow: visible;
}

.rope-drop {
  position: absolute;
  left: 50%;
  top: 16rpx;
  width: 84rpx;
  height: 156rpx;
  transform: translateX(-50%);
}

.rope-drop-strand,
.rope-drop-tail {
  position: absolute;
  top: 0;
  width: 14rpx;
  height: 136rpx;
  border-radius: 1998rpx;
  background:
    repeating-linear-gradient(150deg, rgba(115, 83, 47, 0.24) 0 4rpx, transparent 4rpx 10rpx),
    linear-gradient(90deg, #bfa278 0%, #f1dfbb 42%, #d7bd91 72%, #927043 100%);
  box-shadow:
    2rpx 4rpx 6rpx rgba(46, 27, 13, 0.24),
    inset -2rpx 0 2rpx rgba(96, 65, 34, 0.3);
}

.strand-a {
  left: 30rpx;
  transform: rotate(-3deg);
}

.strand-b {
  left: 40rpx;
  transform: rotate(2deg);
}

.strand-c {
  left: 36rpx;
  opacity: 0.9;
}

.rope-drop-knot {
  position: absolute;
  left: 20rpx;
  top: 54rpx;
  width: 56rpx;
  height: 30rpx;
  border-radius: 50%;
  background:
    repeating-linear-gradient(145deg, rgba(100, 71, 39, 0.18) 0 4rpx, transparent 4rpx 10rpx),
    linear-gradient(90deg, #af8d5d, #f2dfba 44%, #a77f4c);
  box-shadow:
    2rpx 6rpx 12rpx rgba(42, 24, 12, 0.26),
    inset 0 0 8rpx rgba(77, 48, 24, 0.28);
}

.tail-a,
.tail-b {
  top: 84rpx;
  height: 72rpx;
}

.tail-a {
  left: 28rpx;
  transform: rotate(8deg);
}

.tail-b {
  left: 46rpx;
  transform: rotate(-9deg);
}

.rope-note {
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  z-index: 4;
  width: 144rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  padding: 14rpx 12rpx 10rpx;
  transform: translateX(-50%);
  border: 2rpx solid rgba(98, 77, 49, 0.22);
  border-radius: 8rpx;
  box-shadow: 0 10rpx 20rpx rgba(45, 25, 12, 0.22);
}

.note-tone-0 {
  background: linear-gradient(180deg, rgba(239, 246, 222, 0.95), rgba(197, 214, 177, 0.92));
}

.note-tone-1 {
  background: linear-gradient(180deg, rgba(243, 226, 207, 0.95), rgba(218, 190, 164, 0.92));
}

.note-tone-2 {
  background: linear-gradient(180deg, rgba(225, 235, 237, 0.95), rgba(188, 204, 207, 0.92));
}

.note-tone-3 {
  background: linear-gradient(180deg, rgba(240, 226, 232, 0.95), rgba(213, 190, 201, 0.92));
}

.rope-note-name,
.rope-note-count {
  display: block;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rope-note-name {
  color: #3a3027;
  font-size: 24rpx;
  font-weight: 700;
}

.rope-note-count {
  margin-top: 4rpx;
  color: rgba(54, 45, 37, 0.62);
  font-size: 20rpx;
}

.home-control-bar {
  position: absolute;
  z-index: 6;
  left: 50%;
  bottom: 32rpx;
  width: 412rpx;
  height: 116rpx;
  transform: translateX(-50%);
  border-radius: 44rpx;
  background: rgba(244, 226, 185, 0.68);
  border: 2rpx solid rgba(118, 85, 47, 0.22);
  box-shadow:
    inset 0 0 26rpx rgba(255, 247, 218, 0.38),
    0 20rpx 42rpx rgba(62, 41, 22, 0.18);
  display: grid;
  grid-template-columns: repeat(3, 88rpx);
  gap: 20rpx;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: 10rpx 28rpx;
}

.home-control-bar .settings-toggle,
.home-control-bar .home-search-toggle,
.home-control-bar .add-rope-action {
  position: relative;
  display: grid;
  width: 88rpx;
  height: 88rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  border: 0;
  color: #4a4036;
  background: rgba(255, 242, 205, 0.45);
  box-shadow: inset 0 0 16rpx rgba(90, 61, 33, 0.16);
  place-items: center;
  line-height: 1;
  font-size: 0;
}

.home-control-bar button::after {
  border: 0;
}

.home-control-icon {
  display: block;
  width: 64rpx;
  height: 64rpx;
}

.home-popover-scrim {
  position: absolute;
  z-index: 8;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: transparent;
}

.rope-add-page {
  z-index: 4;
}

.add-rope-back,
.back-home-action,
.rope-timeline-toggle {
  position: absolute;
  z-index: 7;
  left: 0;
  top: 156rpx;
  width: 78rpx;
  min-height: 98rpx;
  padding: 12rpx 8rpx;
  box-sizing: border-box;
  border-radius: 12rpx 10rpx 14rpx 10rpx;
  color: #4c4036;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  background-color: rgba(249, 236, 203, 0.82);
  background: rgba(249, 236, 203, 0.78);
  box-shadow: 0 12rpx 26rpx rgba(64, 43, 22, 0.16);
}

.rope-timeline-toggle {
  left: auto;
  right: 0;
}

.back-home-action,
.rope-timeline-toggle {
  top: 232rpx;
  width: 72rpx;
  min-height: 128rpx;
  writing-mode: vertical-rl;
}

.rope-tab-char {
  display: block;
  width: 100%;
  text-align: center;
  line-height: 1.25;
}

.add-rope-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 112rpx;
  bottom: 0;
}

.add-mode-title,
.add-rope-name-card {
  margin: 44rpx auto 0;
  width: 72%;
  box-sizing: border-box;
  padding: 36rpx 24rpx;
  color: #3e342c;
  text-align: center;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 14rpx;
  background:
    linear-gradient(90deg, rgba(113, 87, 53, 0.06), transparent 35%, rgba(113, 87, 53, 0.08)),
    rgba(249, 236, 203, 0.62);
  border: 2rpx solid rgba(102, 75, 43, 0.2);
  box-shadow: 0 14rpx 30rpx rgba(77, 51, 25, 0.12);
}

.rope-mode-options {
  display: flex;
  justify-content: space-between;
  width: 84%;
  margin: 116rpx auto 0;
}

.rope-mode-card {
  width: 42%;
  min-height: 300rpx;
  color: #3b332c;
  text-align: center;
}

.rope-mode-orbit {
  width: 252rpx;
  height: 252rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: rgba(255, 247, 226, 0.38);
  border: 2rpx solid rgba(62, 45, 30, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected .rope-mode-orbit {
  border-color: rgba(126, 65, 43, 0.74);
  box-shadow:
    0 0 0 8rpx rgba(126, 65, 43, 0.1),
    0 16rpx 36rpx rgba(79, 47, 26, 0.16);
}

.rope-mode-image {
  width: 232rpx;
  height: 180rpx;
}

.couple-mode-image {
  width: 272rpx;
}

.rope-mode-label {
  display: block;
  margin-top: 28rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.add-rope-name-card {
  margin-top: 36rpx;
  padding: 30rpx 24rpx;
}

.add-rope-name-input {
  display: block;
  width: 78%;
  height: 86rpx;
  margin: 24rpx auto 0;
  padding: 0 24rpx;
  color: #42382f;
  font-size: 36rpx;
  text-align: center;
  background: rgba(255, 248, 226, 0.82);
  border: 2rpx solid rgba(96, 72, 45, 0.18);
  border-radius: 10rpx;
  box-shadow: inset 0 6rpx 16rpx rgba(73, 48, 24, 0.08);
}

.add-rope-rope {
  width: 84rpx;
  height: 236rpx;
  margin: 44rpx auto 0;
}

.add-rope-tail-image {
  width: 84rpx;
  height: 236rpx;
}

.create-rope-action {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 296rpx;
  height: 128rpx;
  transform: translateX(-50%);
  color: rgba(82, 70, 59, 0.54);
  font-size: 40rpx;
  font-weight: 700;
  border-radius: 152rpx 152rpx 8rpx 8rpx;
  background: rgba(249, 236, 203, 0.68);
  border: 2rpx solid rgba(99, 72, 43, 0.22);
  box-shadow:
    inset 0 16rpx 36rpx rgba(255, 249, 225, 0.34),
    0 12rpx 28rpx rgba(71, 47, 24, 0.12);
}

.create-rope-action.ready {
  color: #4a3322;
  background: rgba(255, 235, 177, 0.88);
  box-shadow:
    inset 0 16rpx 40rpx rgba(255, 252, 222, 0.44),
    0 0 36rpx rgba(222, 166, 63, 0.32);
}

.rope-ui-layer {
  position: absolute;
  z-index: 12;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
}

.back-home-action,
.rope-timeline-toggle,
.record-timeline-dock,
.exchange-dock {
  pointer-events: auto;
}

.stats-bar {
  position: absolute;
  z-index: 4;
  top: 80rpx;
  left: 36rpx;
  right: 36rpx;
  height: 108rpx;
  border-radius: 14rpx;
  background-color: rgba(249, 238, 207, 0.86);
  background: rgba(249, 238, 207, 0.82);
  border: 2rpx solid rgba(99, 72, 43, 0.16);
  box-shadow: 0 14rpx 30rpx rgba(70, 48, 28, 0.09);
}

.stat-item {
  position: absolute;
  top: 14rpx;
  width: 33.333%;
  text-align: center;
}

.stat-item-0 {
  left: 0;
}

.stat-item-1 {
  left: 33.333%;
}

.stat-item-2 {
  left: 66.666%;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.1;
}

.stat-label {
  margin-top: 4rpx;
  color: #766756;
  font-size: 22rpx;
}

.exchange-dock {
  position: absolute;
  z-index: 4;
  left: 40rpx;
  right: 40rpx;
  bottom: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.exchange-tray {
  display: none;
  width: 100%;
  margin-bottom: 18rpx;
}

.exchange-tray.open {
  display: block;
}

.exchange-action {
  width: 100%;
  min-height: 110rpx;
  margin-top: 16rpx;
  padding: 18rpx 30rpx;
  text-align: left;
  border-radius: 14rpx;
  background: rgba(255, 245, 216, 0.9);
  box-shadow: 0 14rpx 32rpx rgba(64, 43, 22, 0.13);
}

.action-label,
.action-hint {
  display: block;
}

.action-label {
  color: #342d27;
  font-size: 32rpx;
  font-weight: 700;
}

.action-hint {
  margin-top: 6rpx;
  color: #7d6f61;
  font-size: 24rpx;
}

.exchange-button {
  width: 256rpx;
  min-height: 108rpx;
  border-radius: 14rpx;
  background-color: rgba(250, 237, 203, 0.94);
  background: rgba(250, 237, 203, 0.92);
  box-shadow:
    0 16rpx 36rpx rgba(62, 41, 22, 0.16),
    inset 0 0 22rpx rgba(255, 247, 219, 0.42);
}

.exchange-mark,
.exchange-sub {
  display: block;
  text-align: center;
}

.exchange-mark {
  font-size: 34rpx;
  font-weight: 700;
}

.exchange-sub {
  margin-top: 4rpx;
  color: #766a5d;
  font-size: 22rpx;
}

.record-timeline-dock,
.settings-dock {
  position: absolute;
  z-index: 9;
  top: 196rpx;
  bottom: 188rpx;
  width: 70%;
  max-width: 600rpx;
  opacity: 0;
  background-color: rgba(252, 242, 214, 0.86);
  transform: translateX(-36rpx);
  transition: opacity 180ms ease, transform 180ms ease;
}

.settings-dock {
  left: 28rpx;
}

.record-timeline-dock {
  right: 28rpx;
  transform: translateX(36rpx);
}

.global-search-dock {
  left: 50%;
  right: auto;
  transform: translateX(-50%) translateY(20rpx);
}

.settings-dock.open,
.record-timeline-dock.open {
  opacity: 1;
  transform: translateX(0);
}

.global-search-dock.open {
  transform: translateX(-50%) translateY(0);
}

.dock-rail,
.settings-list,
.record-timeline-body,
.global-search-body {
  background: rgba(249, 235, 198, 0.9);
  border: 2rpx solid rgba(92, 67, 39, 0.16);
  box-shadow: 0 16rpx 44rpx rgba(66, 43, 20, 0.15);
}

.dock-rail {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 14rpx 14rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dock-close {
  width: 56rpx;
  height: 56rpx;
  color: #6c5743;
  font-size: 44rpx;
}

.settings-list,
.record-timeline-body,
.global-search-body {
  min-height: 360rpx;
  padding: 24rpx;
  border-top: 0;
  border-radius: 0 0 16rpx 16rpx;
}

.drawer-hint,
.settings-action-hint,
.reset-confirm-copy {
  display: block;
  color: #7c6d5e;
  font-size: 24rpx;
  line-height: 1.45;
}

.settings-action {
  width: 100%;
  margin-top: 24rpx;
  padding: 24rpx;
  text-align: left;
  border-radius: 14rpx;
  background: rgba(255, 248, 229, 0.64);
}

.settings-action-label {
  display: block;
  font-weight: 700;
}

.reset-confirm-panel {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 244, 216, 0.72);
}

.reset-confirm-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
}

.record-timeline-list {
  max-height: 640rpx;
  margin-top: 20rpx;
}

