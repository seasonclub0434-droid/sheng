.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  color: #352f2a;
  background:
    radial-gradient(circle at 18% 12%, rgba(110, 83, 52, 0.11), transparent 28%),
    radial-gradient(circle at 82% 86%, rgba(75, 57, 38, 0.09), transparent 30%),
    #a99b7c;
  font-family: "Hannotate SC", "Kaiti SC", "PingFang SC", sans-serif;
}

.page::after {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
  content: "";
  opacity: 0.38;
  background-image:
    linear-gradient(rgba(76, 63, 48, 0.055) 1px, transparent 1px),
    linear-gradient(90deg, rgba(76, 63, 48, 0.04) 1px, transparent 1px);
  background-size: 18px 22px, 29px 31px;
}

.rope-canvas {
  position: absolute;
  z-index: 1;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
}

.canvas-hidden {
  opacity: 0;
  pointer-events: none;
}

.login-gate,
.home-page,
.rope-add-page {
  position: absolute;
  z-index: 2;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
}

.login-gate {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18px 10px;
}

.login-cabinet-frame {
  position: relative;
  width: 100%;
  max-width: 430px;
  height: 92vh;
}

.login-cabinet-image {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 18px 28px rgba(48, 33, 20, 0.28));
}

.login-enter-action {
  position: absolute;
  left: 31.8%;
  top: 57.2%;
  width: 36.4%;
  height: 18%;
  border-radius: 50%;
  background: transparent;
}

.login-enter-glow {
  position: absolute;
  left: 3%;
  right: 3%;
  top: 3%;
  bottom: 3%;
  border-radius: 50%;
  border: 2px solid rgba(244, 208, 112, 0.72);
  box-shadow:
    0 0 12px rgba(255, 224, 132, 0.48),
    inset 0 0 18px rgba(255, 235, 174, 0.22);
  opacity: 0.78;
}

.home-page,
.rope-add-page {
  margin: 34px auto 28px;
  width: calc(100vw - 34px);
  max-width: 430px;
  border-radius: 24px;
  background:
    linear-gradient(92deg, rgba(255, 239, 191, 0.17), transparent 18%, rgba(90, 58, 30, 0.08) 62%, transparent 82%),
    linear-gradient(rgba(71, 52, 34, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(71, 52, 34, 0.035) 1px, transparent 1px),
    #caa36f;
  background-size: auto, 18px 21px, 28px 31px;
  box-shadow:
    inset 0 0 38px rgba(84, 56, 32, 0.16),
    0 18px 40px rgba(43, 32, 22, 0.18);
  overflow: hidden;
}

.home-title-image {
  position: absolute;
  z-index: 4;
  top: 20px;
  left: 50%;
  width: 170px;
  height: 82px;
  transform: translateX(-50%);
}

.rope-shelf {
  position: absolute;
  z-index: 2;
  top: 105px;
  left: 34px;
  right: 34px;
  bottom: 96px;
  overflow: hidden;
}

.cabinet-stack {
  position: relative;
  min-height: 100%;
  padding-top: 12px;
  padding-bottom: 12px;
  border-radius: 7px;
  background:
    linear-gradient(90deg, rgba(48, 27, 12, 0.55), transparent 5%, transparent 95%, rgba(48, 27, 12, 0.55)),
    #8e551f;
  box-shadow:
    inset 0 0 0 1px rgba(45, 23, 10, 0.55),
    inset 0 0 24px rgba(45, 24, 11, 0.44);
}

.cabinet-top,
.cabinet-bottom {
  display: block;
  height: 17px;
  margin: 0 0 0;
  border-radius: 8px;
  background:
    linear-gradient(180deg, #c57a26 0%, #8d4d16 52%, #5f2f0e 100%);
  box-shadow:
    inset 0 2px 4px rgba(255, 210, 116, 0.25),
    inset 0 -6px 10px rgba(42, 22, 10, 0.38),
    0 2px 7px rgba(31, 19, 11, 0.45);
}

.cabinet-bottom {
  margin-top: 0;
}

.cabinet-row {
  position: relative;
  height: 135px;
  overflow: hidden;
}

.cabinet-back {
  position: absolute;
  left: 8px;
  right: 8px;
  top: 10px;
  bottom: 22px;
  border-radius: 8px;
  background:
    linear-gradient(90deg, rgba(48, 26, 12, 0.2), transparent 22%, rgba(52, 28, 14, 0.2) 50%, transparent 76%, rgba(48, 26, 12, 0.2)),
    linear-gradient(rgba(68, 37, 16, 0.1) 1px, transparent 1px),
    #9a6028;
  background-size: auto, 14px 18px;
  box-shadow: inset 0 10px 20px rgba(38, 21, 10, 0.42);
}

.cabinet-back::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 12px;
  content: "";
  transform: translateX(-50%);
  background: linear-gradient(90deg, rgba(42, 21, 9, 0.18), rgba(218, 144, 57, 0.42), rgba(42, 21, 9, 0.2));
  box-shadow: 0 0 10px rgba(35, 19, 9, 0.35);
}

.cabinet-slots {
  position: absolute;
  z-index: 2;
  top: 7px;
  left: 0;
  right: 0;
  height: 108px;
  display: flex;
  justify-content: space-around;
}

.cabinet-slot {
  position: relative;
  width: 45%;
  height: 110px;
}

.empty-slot {
  opacity: 0.1;
}

.cabinet-front {
  position: absolute;
  z-index: 3;
  left: 0;
  right: 0;
  bottom: 0;
  height: 30px;
  border-radius: 4px;
  background:
    linear-gradient(180deg, rgba(255, 187, 74, 0.48), transparent 21%),
    linear-gradient(180deg, #bd721e 0%, #8a4a12 46%, #5a2d0c 100%);
  box-shadow:
    inset 0 2px 5px rgba(255, 213, 122, 0.2),
    inset 0 -8px 11px rgba(43, 22, 8, 0.38),
    0 -1px 7px rgba(38, 20, 9, 0.4);
}

.rope-tile {
  overflow: visible;
}

.rope-drop {
  position: absolute;
  left: 50%;
  top: 8px;
  width: 42px;
  height: 78px;
  transform: translateX(-50%);
}

.rope-drop-strand,
.rope-drop-tail {
  position: absolute;
  top: 0;
  width: 7px;
  height: 68px;
  border-radius: 999px;
  background:
    repeating-linear-gradient(150deg, rgba(115, 83, 47, 0.24) 0 2px, transparent 2px 5px),
    linear-gradient(90deg, #bfa278 0%, #f1dfbb 42%, #d7bd91 72%, #927043 100%);
  box-shadow:
    1px 2px 3px rgba(46, 27, 13, 0.24),
    inset -1px 0 1px rgba(96, 65, 34, 0.3);
}

.strand-a {
  left: 15px;
  transform: rotate(-3deg);
}

.strand-b {
  left: 20px;
  transform: rotate(2deg);
}

.strand-c {
  left: 18px;
  opacity: 0.9;
}

.rope-drop-knot {
  position: absolute;
  left: 10px;
  top: 27px;
  width: 28px;
  height: 15px;
  border-radius: 50%;
  background:
    repeating-linear-gradient(145deg, rgba(100, 71, 39, 0.18) 0 2px, transparent 2px 5px),
    linear-gradient(90deg, #af8d5d, #f2dfba 44%, #a77f4c);
  box-shadow:
    1px 3px 6px rgba(42, 24, 12, 0.26),
    inset 0 0 4px rgba(77, 48, 24, 0.28);
}

.tail-a,
.tail-b {
  top: 42px;
  height: 36px;
}

.tail-a {
  left: 14px;
  transform: rotate(8deg);
}

.tail-b {
  left: 23px;
  transform: rotate(-9deg);
}

.rope-note {
  position: absolute;
  left: 50%;
  bottom: -4px;
  z-index: 4;
  width: 72px;
  min-height: 38px;
  box-sizing: border-box;
  padding: 7px 6px 5px;
  transform: translateX(-50%) rotate(-0.8deg);
  border: 1px solid rgba(98, 77, 49, 0.22);
  border-radius: 4px;
  box-shadow: 0 5px 10px rgba(45, 25, 12, 0.22);
}

.note-tone-0 {
  background: linear-gradient(180deg, rgba(239, 246, 222, 0.95), rgba(197, 214, 177, 0.92));
}

.note-tone-1 {
  background: linear-gradient(180deg, rgba(243, 226, 207, 0.95), rgba(218, 190, 164, 0.92));
}

.note-tone-2 {
  background: linear-gradient(180deg, rgba(225, 235, 237, 0.95), rgba(188, 204, 207, 0.92));
}

.note-tone-3 {
  background: linear-gradient(180deg, rgba(240, 226, 232, 0.95), rgba(213, 190, 201, 0.92));
}

.rope-note-name,
.rope-note-count {
  display: block;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rope-note-name {
  color: #3a3027;
  font-size: 12px;
  font-weight: 700;
}

.rope-note-count {
  margin-top: 2px;
  color: rgba(54, 45, 37, 0.62);
  font-size: 10px;
}

.home-control-bar {
  position: absolute;
  z-index: 6;
  left: 50%;
  bottom: 22px;
  width: 206px;
  height: 58px;
  transform: translateX(-50%);
  border-radius: 22px;
  background: rgba(244, 226, 185, 0.68);
  border: 1px solid rgba(118, 85, 47, 0.22);
  box-shadow:
    inset 0 0 13px rgba(255, 247, 218, 0.38),
    0 10px 21px rgba(62, 41, 22, 0.18);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.settings-toggle,
.timeline-toggle,
.add-rope-action {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  color: #4a4036;
  background: rgba(255, 242, 205, 0.45);
  box-shadow: inset 0 0 8px rgba(90, 61, 33, 0.16);
}

.add-rope-plus,
.control-icon {
  display: block;
  font-size: 25px;
  line-height: 46px;
  text-align: center;
  font-weight: 700;
}

.settings-gear-logo {
  font-size: 24px;
}

.search-icon {
  font-size: 31px;
  transform: rotate(-12deg);
}

.rope-add-page {
  z-index: 4;
}

.add-rope-back,
.back-home-action,
.rope-timeline-toggle {
  position: absolute;
  z-index: 7;
  left: 8px;
  top: 90px;
  width: 58px;
  height: 76px;
  border-radius: 6px 5px 7px 5px;
  color: #4c4036;
  font-size: 16px;
  font-weight: 700;
  background: rgba(249, 236, 203, 0.78);
  box-shadow: 0 6px 13px rgba(64, 43, 22, 0.16);
}

.rope-timeline-toggle {
  left: auto;
  right: 8px;
}

.add-rope-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 46px;
  bottom: 0;
}

.add-mode-title,
.add-rope-name-card {
  margin: 22px auto 0;
  width: 72%;
  box-sizing: border-box;
  padding: 18px 12px;
  color: #3e342c;
  text-align: center;
  font-size: 19px;
  font-weight: 700;
  border-radius: 7px;
  background:
    linear-gradient(90deg, rgba(113, 87, 53, 0.06), transparent 35%, rgba(113, 87, 53, 0.08)),
    rgba(249, 236, 203, 0.62);
  border: 1px solid rgba(102, 75, 43, 0.2);
  box-shadow: 0 7px 15px rgba(77, 51, 25, 0.12);
}

.rope-mode-options {
  display: flex;
  justify-content: space-between;
  width: 84%;
  margin: 58px auto 0;
}

.rope-mode-card {
  width: 42%;
  min-height: 150px;
  color: #3b332c;
  text-align: center;
}

.rope-mode-orbit {
  width: 126px;
  height: 126px;
  margin: 0 auto;
  border-radius: 50%;
  background: rgba(255, 247, 226, 0.38);
  border: 1px solid rgba(62, 45, 30, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected .rope-mode-orbit {
  border-color: rgba(126, 65, 43, 0.74);
  box-shadow:
    0 0 0 4px rgba(126, 65, 43, 0.1),
    0 8px 18px rgba(79, 47, 26, 0.16);
}

.rope-mode-image {
  width: 116px;
  height: 90px;
}

.couple-mode-image {
  width: 136px;
}

.rope-mode-label {
  display: block;
  margin-top: 14px;
  font-size: 19px;
  font-weight: 700;
}

.add-rope-name-card {
  margin-top: 18px;
  padding: 15px 12px;
}

.add-rope-name-input {
  display: block;
  width: 78%;
  height: 43px;
  margin: 12px auto 0;
  padding: 0 12px;
  color: #42382f;
  font-size: 18px;
  text-align: center;
  background: rgba(255, 248, 226, 0.82);
  border: 1px solid rgba(96, 72, 45, 0.18);
  border-radius: 5px;
  box-shadow: inset 0 3px 8px rgba(73, 48, 24, 0.08);
}

.add-rope-rope {
  width: 42px;
  height: 118px;
  margin: 22px auto 0;
}

.add-rope-tail-image {
  width: 42px;
  height: 118px;
}

.create-rope-action {
  position: absolute;
  left: 50%;
  bottom: 16px;
  width: 148px;
  height: 64px;
  transform: translateX(-50%);
  color: rgba(82, 70, 59, 0.54);
  font-size: 20px;
  font-weight: 700;
  border-radius: 76px 76px 4px 4px;
  background: rgba(249, 236, 203, 0.68);
  border: 1px solid rgba(99, 72, 43, 0.22);
  box-shadow:
    inset 0 8px 18px rgba(255, 249, 225, 0.34),
    0 6px 14px rgba(71, 47, 24, 0.12);
}

.create-rope-action.ready {
  color: #4a3322;
  background: rgba(255, 235, 177, 0.88);
  box-shadow:
    inset 0 8px 20px rgba(255, 252, 222, 0.44),
    0 0 18px rgba(222, 166, 63, 0.32);
}

.rope-ui-layer {
  position: absolute;
  z-index: 3;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.rope-ui-layer button,
.rope-ui-layer .exchange-dock,
.rope-ui-layer .stats-bar,
.rope-ui-layer .record-timeline-dock {
  pointer-events: auto;
}

.stats-bar {
  position: absolute;
  top: 40px;
  left: 18px;
  right: 18px;
  height: 54px;
  border-radius: 7px;
  background: rgba(249, 238, 207, 0.82);
  border: 1px solid rgba(99, 72, 43, 0.16);
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 7px 15px rgba(70, 48, 28, 0.09);
}

.stat-item {
  min-width: 70px;
  text-align: center;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  font-size: 19px;
  font-weight: 700;
  line-height: 1.1;
}

.stat-label {
  margin-top: 2px;
  color: #766756;
  font-size: 11px;
}

.exchange-dock {
  position: absolute;
  left: 20px;
  right: 20px;
  bottom: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.exchange-tray {
  display: none;
  width: 100%;
  margin-bottom: 9px;
}

.exchange-tray.open {
  display: block;
}

.exchange-action {
  width: 100%;
  min-height: 55px;
  margin-top: 8px;
  padding: 9px 15px;
  text-align: left;
  border-radius: 7px;
  background: rgba(255, 245, 216, 0.9);
  box-shadow: 0 7px 16px rgba(64, 43, 22, 0.13);
}

.action-label,
.action-hint {
  display: block;
}

.action-label {
  color: #342d27;
  font-size: 16px;
  font-weight: 700;
}

.action-hint {
  margin-top: 3px;
  color: #7d6f61;
  font-size: 12px;
}

.exchange-button {
  width: 128px;
  min-height: 54px;
  border-radius: 7px;
  background: rgba(250, 237, 203, 0.92);
  box-shadow:
    0 8px 18px rgba(62, 41, 22, 0.16),
    inset 0 0 11px rgba(255, 247, 219, 0.42);
}

.exchange-mark,
.exchange-sub {
  display: block;
  text-align: center;
}

.exchange-mark {
  font-size: 17px;
  font-weight: 700;
}

.exchange-sub {
  margin-top: 2px;
  color: #766a5d;
  font-size: 11px;
}

.record-timeline-dock,
.settings-dock {
  position: absolute;
  z-index: 9;
  top: 98px;
  bottom: 94px;
  width: 70%;
  max-width: 300px;
  opacity: 0;
  pointer-events: none;
  transform: translateX(-18px);
  transition: opacity 180ms ease, transform 180ms ease;
}

.settings-dock {
  left: 14px;
}

.record-timeline-dock {
  right: 14px;
  transform: translateX(18px);
}

.global-search-dock {
  left: 50%;
  right: auto;
  transform: translateX(-50%) translateY(10px);
}

.settings-dock.open,
.record-timeline-dock.open {
  opacity: 1;
  pointer-events: auto;
  transform: translateX(0);
}

.global-search-dock.open {
  transform: translateX(-50%) translateY(0);
}

.dock-rail,
.settings-list,
.record-timeline-body,
.global-search-body {
  background: rgba(249, 235, 198, 0.9);
  border: 1px solid rgba(92, 67, 39, 0.16);
  box-shadow: 0 8px 22px rgba(66, 43, 20, 0.15);
}

.dock-rail {
  height: 42px;
  padding: 0 12px;
  border-radius: 7px 7px 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dock-close {
  width: 28px;
  height: 28px;
  color: #6c5743;
  font-size: 22px;
}

.settings-list,
.record-timeline-body,
.global-search-body {
  min-height: 180px;
  padding: 12px;
  border-top: 0;
  border-radius: 0 0 8px 8px;
}

.drawer-hint,
.settings-action-hint,
.reset-confirm-copy {
  display: block;
  color: #7c6d5e;
  font-size: 12px;
  line-height: 1.45;
}

.settings-action {
  width: 100%;
  margin-top: 12px;
  padding: 12px;
  text-align: left;
  border-radius: 7px;
  background: rgba(255, 248, 229, 0.64);
}

.settings-action-label {
  display: block;
  font-weight: 700;
}

.reset-confirm-panel {
  margin-top: 12px;
  padding: 10px;
  border-radius: 7px;
  background: rgba(255, 244, 216, 0.72);
}

.reset-confirm-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 10px;
}

.record-timeline-list {
  max-height: 320px;
  margin-top: 10px;
}

.record-timeline-item,
.global-search-item {
  display: block;
  width: 100%;
  margin-bottom: 8px;
  padding: 9px 10px;
  text-align: left;
  border-radius: 6px;
  background: rgba(255, 249, 231, 0.58);
}

.record-timeline-item.selected {
  box-shadow: inset 0 0 0 2px rgba(176, 37, 31, 0.7);
}

.record-timeline-date,
.record-timeline-copy,
.global-search-rope,
.global-search-copy {
  display: block;
}

.record-timeline-date,
.global-search-rope {
  font-size: 12px;
  color: #896f55;
}

.record-timeline-copy,
.global-search-copy {
  margin-top: 3px;
  font-size: 13px;
  color: #3d342c;
}

.global-search-box {
  display: flex;
  align-items: center;
  height: 38px;
  padding: 0 10px;
  border-radius: 7px;
  background: rgba(255, 249, 229, 0.68);
}

.global-search-box input {
  flex: 1;
  height: 34px;
  margin-left: 7px;
  font-size: 14px;
}

.floating-note {
  position: absolute;
  left: 50%;
  bottom: 106px;
  z-index: 12;
  box-sizing: border-box;
  max-width: 260px;
  padding: 11px 14px;
  color: #6b5d50;
  font-size: 13px;
  line-height: 1.45;
  text-align: center;
  background: rgba(248, 241, 225, 0.9);
  border: 1px solid rgba(97, 78, 56, 0.14);
  border-radius: 8px 7px 9px 6px;
  transform: translateX(-50%) rotate(-1deg);
}

.modal-mask {
  position: absolute;
  z-index: 20;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  box-sizing: border-box;
  padding: 20px 18px 30px;
  background: rgba(58, 49, 40, 0.12);
}

.paper-card {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  max-width: 430px;
  padding: 20px 18px 16px;
  background:
    linear-gradient(98deg, rgba(111, 88, 60, 0.05), transparent 34%),
    #fbf3dc;
  border: 1px solid rgba(92, 70, 46, 0.22);
  border-radius: 8px 7px 9px 6px;
  box-shadow: 0 10px 28px rgba(65, 52, 38, 0.08);
}

.card-title {
  color: #3a3129;
  font-size: 18px;
  font-weight: 700;
  line-height: 1.3;
}

.card-meta {
  margin-top: 4px;
  color: #8a7b69;
  font-size: 12px;
}

.note-input,
.resolve-input {
  width: 100%;
  color: #3b332c;
  font-size: 16px;
  line-height: 1.6;
  background: rgba(255, 251, 240, 0.55);
  border: 1px solid rgba(93, 70, 44, 0.15);
  border-radius: 7px;
}

.note-input {
  height: 168px;
  margin-top: 15px;
  padding: 12px;
}

.resolve-input {
  height: 86px;
  margin-top: 12px;
  padding: 10px;
  font-size: 14px;
}

.input-placeholder {
  color: #b4a58e;
}

.detail-content {
  min-height: 68px;
  margin-top: 14px;
  padding: 12px;
  color: #4b4036;
  font-size: 15px;
  line-height: 1.65;
  white-space: pre-wrap;
  background: rgba(255, 250, 239, 0.46);
  border: 1px solid rgba(93, 70, 44, 0.11);
  border-radius: 7px;
}

.pending-box,
.resolution-lines {
  margin-top: 12px;
  color: #6b5c4f;
  font-size: 13px;
  line-height: 1.55;
}

.line-note {
  margin-top: 8px;
  padding: 9px 10px;
  background: rgba(239, 228, 207, 0.62);
  border-left: 3px solid rgba(157, 86, 66, 0.48);
  border-radius: 5px;
}

.line-note-right {
  margin-left: 26px;
  border-left-color: rgba(82, 122, 126, 0.44);
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-top: 16px;
}

.text-button,
.ink-button {
  min-width: 72px;
  box-sizing: border-box;
  margin-left: 10px;
  padding: 11px 14px;
  font-size: 14px;
  border-radius: 7px;
}

.text-button {
  color: #7b6b5c;
}

.ink-button {
  color: #f9f1df;
  background: #6e5a47;
  border: 1px solid rgba(48, 35, 24, 0.22);
}

.notebook-card {
  max-height: 78vh;
}

.notebook-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.notebook-search {
  width: 120px;
  height: 34px;
  padding: 0 9px;
  border-radius: 6px;
  background: rgba(255, 250, 233, 0.72);
}

.notebook-list {
  max-height: 360px;
  margin-top: 12px;
}

.notebook-item {
  margin-bottom: 9px;
  padding: 10px;
  border-radius: 7px;
  background: rgba(255, 249, 231, 0.55);
}

.notebook-item-title,
.notebook-item-meta,
.notebook-item-content {
  display: block;
}

.notebook-item-title {
  font-weight: 700;
}

.notebook-item-meta {
  margin-top: 3px;
  color: #8a7b69;
  font-size: 12px;
}

.notebook-item-content {
  margin-top: 6px;
  color: #4b4036;
  font-size: 13px;
  line-height: 1.5;
}
