}

.cabinet-row {
  position: relative;
  z-index: 1;
  height: 270rpx;
  box-sizing: border-box;
  padding: 18rpx 34rpx 58rpx;
  overflow: visible;
  transform: none;
}

.cabinet-row::before,
.cabinet-row::after {
  position: absolute;
