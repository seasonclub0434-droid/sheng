  background:
    linear-gradient(90deg, rgba(31, 16, 6, 0.28), transparent 6% 94%, rgba(31, 16, 6, 0.28)),
    repeating-linear-gradient(90deg, rgba(255, 203, 116, 0.05) 0 2rpx, transparent 2rpx 34rpx),
    radial-gradient(circle at 23% 18%, rgba(53, 25, 8, 0.18), transparent 8%),
    radial-gradient(circle at 78% 72%, rgba(255, 214, 144, 0.08), transparent 9%);
  box-shadow:
    inset 0 36rpx 48rpx rgba(28, 14, 5, 0.2),
    inset 0 -20rpx 36rpx rgba(234, 158, 65, 0.06);
}

.cabinet-stack::after {
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 13;
  opacity: 0.5;
  border-radius: inherit;
  background:
    linear-gradient(108deg, transparent 0 21%, rgba(255, 213, 133, 0.14) 22%, rgba(42, 21, 7, 0.11) 23%, transparent 24% 100%),
    radial-gradient(circle at 17% 32%, rgba(30, 15, 5, 0.15) 0 2rpx, transparent 4rpx),
    repeating-linear-gradient(7deg, transparent 0 22rpx, rgba(43, 21, 7, 0.08) 22rpx 24rpx, transparent 24rpx 58rpx);
}

.cabinet-top,
.cabinet-bottom {
  position: absolute;
  right: 0;
  left: 0;
  z-index: 14;
  height: 26rpx;
  margin: 0;
  border-radius: 20rpx 20rpx 4rpx 4rpx;
  background:
    linear-gradient(180deg, rgba(150, 83, 29, 0.78), rgba(73, 37, 12, 0.9)),
    radial-gradient(ellipse at 28% 38%, rgba(255, 203, 118, 0.08), transparent 22%),
    repeating-linear-gradient(8deg, rgba(255, 211, 130, 0.07) 0 2rpx, transparent 2rpx 20rpx);
  box-shadow:
    0 10rpx 18rpx rgba(33, 17, 6, 0.14),
    inset 0 4rpx 0 rgba(231, 158, 66, 0.06),
    inset 0 -8rpx 14rpx rgba(33, 15, 4, 0.16);
}

.cabinet-top {
  top: 16rpx;
}

.cabinet-bottom {
