  border: 2rpx solid rgba(47, 26, 10, 0.36);
  border-radius: 26rpx 20rpx 32rpx 24rpx;
  background:
    radial-gradient(ellipse at 12% 10%, rgba(239, 178, 87, 0.2), transparent 28%),
    radial-gradient(ellipse at 84% 22%, rgba(54, 28, 9, 0.22), transparent 34%),
    radial-gradient(ellipse at 50% 96%, rgba(49, 24, 6, 0.3), transparent 38%),
    linear-gradient(90deg, rgba(74, 39, 13, 0.9), rgba(153, 91, 34, 0.86) 13%, rgba(111, 65, 24, 0.82) 50%, rgba(160, 94, 35, 0.85) 87%, rgba(61, 31, 10, 0.92)),
    repeating-linear-gradient(96deg, rgba(236, 171, 86, 0.12) 0 2rpx, transparent 2rpx 26rpx);
  box-shadow:
    0 36rpx 60rpx rgba(47, 28, 11, 0.2),
    inset 28rpx 0 36rpx rgba(38, 20, 8, 0.3),
    inset -24rpx 0 40rpx rgba(244, 169, 73, 0.08),
    inset 0 24rpx 36rpx rgba(245, 184, 91, 0.08),
    inset 0 -28rpx 36rpx rgba(39, 20, 7, 0.2);
}

.cabinet-stack::before,
.cabinet-stack::after,
.cabinet-top,
.cabinet-bottom {
  position: absolute;
  pointer-events: none;
  content: "";
}

.cabinet-stack::before {
  top: 24rpx;
