}

.rope-tile {
  position: relative;
  z-index: 17;
  display: block;
  width: 100%;
  height: 200rpx;
  margin: 0;
  padding: 8rpx 0 0;
  box-sizing: border-box;
  overflow: visible;
  line-height: 1;
  background: transparent;
  border: 0;
  pointer-events: auto;
  transform: none;
  --tile-shift-x: 0rpx;
  --tile-center-shift-x: 0rpx;
  --tile-rope-x: calc(50% + var(--tile-center-shift-x) + var(--tile-shift-x));
}

.rope-tile::after {
  display: none;
  position: absolute;
  top: 2rpx;
  left: var(--tile-rope-x);
  z-index: 1;
  width: 26rpx;
  height: 72rpx;
  pointer-events: none;
  content: "";
  background:
    repeating-linear-gradient(164deg, rgba(88, 61, 34, 0.26) 0 2rpx, transparent 2rpx 10rpx),
    repeating-linear-gradient(26deg, rgba(255, 244, 216, 0.22) 0 2rpx, transparent 2rpx 14rpx),
    linear-gradient(90deg, #7f6040 0%, #af8d61 18%, #d8bf99 39%, #f1dfbd 53%, #d4ba92 67%, #a58155 84%, #6d4f31 100%);
  background-blend-mode: multiply, screen, normal;
  border-radius: 999rpx;
  box-shadow:
    4rpx 6rpx 0 rgba(86, 63, 37, 0.2),
    inset 3rpx 0 0 rgba(255, 247, 222, 0.42),
    inset -3rpx 0 0 rgba(74, 48, 24, 0.2);
  opacity: 0.92;
  clip-path: polygon(25% 0, 76% 0, 73% 14%, 82% 29%, 73% 47%, 79% 63%, 72% 82%, 77% 100%, 23% 100%, 17% 82%, 27% 64%, 20% 47%, 29% 29%, 22% 14%);
  transform: translateX(-50%);
  transform-origin: 50% 100%;
}

.rope-coil {
  position: absolute;
  top: -8rpx;
  left: var(--tile-rope-x);
  z-index: 2;
  display: block;
  width: 112rpx;
  height: 154rpx;
  margin-top: 0;
  filter:
    drop-shadow(0 10rpx 9rpx rgba(43, 25, 9, 0.22))
    contrast(1.02);
  transform: translateX(-50%);
  transform-origin: 50% 8rpx;
}

.rope-coil-image {
  display: block;
  width: 112rpx;
  height: 154rpx;
}

.rope-tile.entering-rope .rope-coil {
  animation: ropeTileEnterPull 220ms ease-out both;
}

.rope-tile.entering-rope .rope-note {
  animation: ropeNoteEnterPull 220ms ease-out both;
}

@keyframes ropeTileEnterPull {
  0% {
    filter:
      drop-shadow(0 10rpx 9rpx rgba(43, 25, 9, 0.22))
      contrast(1.02);
    transform: translateX(-50%) translateY(0) scale(1);
  }

  100% {
    filter:
      drop-shadow(0 15rpx 12rpx rgba(43, 25, 9, 0.26))
      contrast(1.05);
    transform: translateX(-50%) translateY(-5rpx) scale(1.035);
  }
}

@keyframes ropeNoteEnterPull {
  0% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) rotate(-0.5deg) scale(1);
  }

  100% {
    opacity: 0.78;
    transform: translateX(-50%) translateY(8rpx) rotate(-0.5deg) scale(0.96);
  }
}

.rope-note {
  left: var(--tile-rope-x);
  bottom: -50rpx;
  z-index: 12;
  width: 144rpx;
  min-height: 78rpx;
  padding: 12rpx 10rpx 10rpx;
