<view class="page {{viewMode}}-mode">
  <canvas
    wx:if="{{viewMode === 'rope'}}"
    id="ropeCanvas"
    canvas-id="ropeCanvas"
    type="2d"
    class="rope-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
    bindtouchstart="onCanvasTouchStart"
    bindtouchmove="onCanvasTouchMove"
    bindtouchend="onCanvasTouchEnd"
  ></canvas>

  <view
    wx:if="{{viewMode === 'login'}}"
    id="loginGate"
    class="login-gate image-login-gate"
    aria-label="绳记登录"
    bindtap="enterLoginGate"
  >
    <view class="login-cabinet-frame">
      <image
        class="login-cabinet-image"
        src="../../assets/login-cabinet-door.png"
        mode="aspectFill"
      />
      <button
        id="loginEnterAction"
        class="login-enter-action image-login-enter-action"
        type="button"
        bindtap="enterLoginGate"
        aria-label="进入我的绳"
      >
        <view class="login-enter-glow"></view>
      </button>
    </view>
  </view>

  <view wx:if="{{viewMode === 'home'}}" id="homePage" class="home-page" aria-label="我的绳">
    <image
      class="home-title-image"
      src="../../assets/home-rope-sign-transparent.png"
      mode="aspectFit"
      style="top: {{safeTop + 8}}px;"
    />

    <scroll-view id="ropeShelf" class="rope-shelf" scroll-y enable-flex style="top: {{safeTop + 90}}px;">
      <view class="home-shelf-stage" style="height: {{homeShelfHeight}}px;">
        <view class="cabinet-stack home-hit-stack" style="height: {{homeShelfHeight}}px;">
          <view class="cabinet-top"></view>
          <block wx:for="{{homeRows}}" wx:key="rowIndex">
            <view class="cabinet-row" style="--row-index: {{item.rowIndex}}; --row-center: {{item.rowCenter}};">
              <view class="cabinet-back"></view>
              <view class="cabinet-slots">
                <block wx:for="{{item.slots}}" wx:key="slotKey" wx:for-item="slot">
                  <button
                    wx:if="{{slot.ropeId}}"
                    class="cabinet-slot rope-tile"
                    type="button"
                    data-rope-id="{{slot.ropeId}}"
                    style="--tile-index: {{slot.tileIndex}}; --tile-shift-x: {{slot.visualShiftX}}rpx;"
                    bindtap="enterRopeFromShelf"
                    aria-label="打开{{slot.name}}"
                  >
                    <view class="rope-coil">
                      <view class="rope-coil-line rope-coil-line-a"></view>
                      <view class="rope-coil-line rope-coil-line-b"></view>
                      <view class="rope-coil-line rope-coil-line-c"></view>
                    </view>
                    <view class="rope-note note-tone-{{slot.noteTone}}">
                      <text class="rope-note-name">{{slot.name}}</text>
                      <text class="rope-note-count">{{slot.openCount}}结 · {{slot.resolvedCount}}解</text>
                    </view>
                  </button>
                  <view wx:else class="cabinet-slot empty-slot"></view>
                </block>
              </view>
              <view class="cabinet-front"></view>
            </view>
          </block>
          <view class="cabinet-bottom"></view>
        </view>
      </view>
    </scroll-view>

    <view class="home-control-bar" aria-label="主页操作">
      <button id="settingsToggle" class="settings-toggle" type="button" bindtap="toggleSettingsDock" aria-label="打开设置">
        <image class="home-control-icon settings-icon-image" src="../../assets/home-icon-settings.png" mode="aspectFit" />
      </button>
      <button id="addRopeAction" class="add-rope-action" type="button" bindtap="openAddRopePage" aria-label="添加绳">
        <image class="home-control-icon create-icon-image" src="../../assets/home-icon-create.png" mode="aspectFit" />
      </button>
      <button id="homeSearchToggle" class="timeline-toggle home-search-toggle" type="button" bindtap="toggleGlobalSearchDock" aria-label="打开搜索">
        <image class="home-control-icon search-icon-image" src="../../assets/home-icon-search.png" mode="aspectFit" />
      </button>
    </view>

    <view wx:if="{{settingsOpen}}" id="settingsDock" class="settings-dock open" catchtouchmove="noop" style="top: {{safeTop + 112}}px;">
      <view class="dock-rail">
        <text class="settings-title">设置</text>
        <button class="dock-close" type="button" bindtap="closeSettingsDock">×</button>
      </view>
      <view class="settings-list">
        <text class="drawer-hint">点 × 收起，重置前会再确认。</text>
        <button class="settings-action reset-preview-action" type="button" bindtap="askResetConfirmation">
          <text class="settings-action-label">重置预览</text>
          <text class="settings-action-hint">清空本机记录，回到空柜子</text>
        </button>
        <view wx:if="{{resetConfirmOpen}}" class="reset-confirm-panel">
          <text class="reset-confirm-copy">确认后会清空本机保存的绳、结、印记和选中状态。</text>
          <view class="reset-confirm-actions">
            <button class="text-button" type="button" bindtap="cancelResetConfirmation">取消</button>
            <button class="ink-button" type="button" bindtap="confirmResetPreview">确认重置</button>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{globalSearchOpen}}" id="globalSearchDock" class="record-timeline-dock global-search-dock open" catchtouchmove="noop" style="top: {{safeTop + 88}}px;">
      <view class="dock-rail">
        <text class="record-timeline-title">搜索</text>
        <button class="dock-close" type="button" bindtap="closeGlobalSearchDock">×</button>
      </view>
      <view class="global-search-body">
        <view class="global-search-box">
          <text>⌕</text>
          <input id="globalSearchInput" type="text" value="{{globalSearchText}}" placeholder="搜所有绳" bindinput="onGlobalSearchInput" />
        </view>
        <view id="globalSearchList" class="global-search-list">
          <view wx:if="{{!globalSearchText}}" class="global-search-empty">写下关键词，会从每根绳里一起找。</view>
          <block wx:else>
            <view wx:if="{{!globalSearchResults.length}}" class="global-search-empty">没有找到这段绳记。</view>
            <block wx:else>
              <block wx:for="{{globalSearchResults}}" wx:key="id">
                <button class="global-search-entry" type="button" data-rope-id="{{item.ropeId}}" bindtap="enterRopeFromShelf">
                  <text class="global-search-rope">{{item.ropeName}}</text>
                  <text class="global-search-copy">{{item.content}}</text>
                </button>
              </block>
            </block>
          </block>
        </view>
      </view>
    </view>
  </view>

  <block wx:if="{{viewMode === 'rope' && !showNote && !showDetail && !showNotebook}}">
    <cover-view id="statsBar" class="stats-bar" style="top: {{safeTop + 22}}px;">
      <block wx:for="{{statsItems}}" wx:key="label">
        <cover-view class="stat-item stat-item-{{index}}">
          <cover-view class="stat-value">{{item.value}}</cover-view>
          <cover-view class="stat-label">{{item.label}}</cover-view>
        </cover-view>
      </block>
    </cover-view>

    <cover-view id="backHomeAction" class="back-home-action" bindtap="goHome" style="top: {{safeTop + 122}}px;">
      <cover-view class="rope-tab-char">返</cover-view>
      <cover-view class="rope-tab-char">回</cover-view>
    </cover-view>
    <cover-view id="timelineToggle" class="timeline-toggle rope-timeline-toggle" bindtap="toggleTimelineDock" style="top: {{safeTop + 122}}px;">
      <cover-view class="rope-tab-char">绳</cover-view>
      <cover-view class="rope-tab-char">历</cover-view>
    </cover-view>

    <cover-view wx:if="{{timelineOpen}}" id="recordTimelineDock" class="record-timeline-dock open" catchtouchmove="noop" style="top: {{safeTop + 112}}px;">
      <cover-view class="dock-rail">
        <cover-view class="record-timeline-title">绳历</cover-view>
        <cover-view class="dock-close" bindtap="closeTimelineDock">×</cover-view>
      </cover-view>
      <cover-view class="record-timeline-body">
        <cover-view class="drawer-hint timeline-hint">点日期会圈住绳上的位置，再点一次取消。</cover-view>
        <cover-view id="recordTimelineList" class="record-timeline-list">
          <block wx:for="{{recordTimelineItems}}" wx:key="id">
            <cover-view class="record-timeline-item {{selectedTimelineId === item.id ? 'selected' : ''}}" data-event-id="{{item.id}}" bindtap="selectTimelineItem">
              <cover-view class="record-timeline-date">{{item.date}}</cover-view>
              <cover-view class="record-timeline-copy">{{item.title}}</cover-view>
            </cover-view>
          </block>
        </cover-view>
      </cover-view>
    </cover-view>

    <cover-view id="exchangeDock" class="exchange-dock" aria-label="记绳操作">
      <cover-view wx:if="{{exchangeOpen}}" id="exchangeTray" class="exchange-tray open">
        <cover-view class="exchange-action write-action" bindtap="openWriteKnot">
          <cover-view class="action-label">写一个结</cover-view>
          <cover-view class="action-hint">把没说完的话系上</cover-view>
        </cover-view>
        <cover-view class="exchange-action resolve-action" bindtap="openLatestResolve">
          <cover-view class="action-label">解一个结</cover-view>
          <cover-view class="action-hint">翻开最近的未解</cover-view>
        </cover-view>
        <cover-view class="exchange-action notebook-action" bindtap="openNotebook">
          <cover-view class="action-label">翻绳本</cover-view>
          <cover-view class="action-hint">回看已解的结和印章</cover-view>
        </cover-view>
      </cover-view>
      <cover-view id="exchangeButton" class="exchange-button" bindtap="toggleExchangeDock">
        <cover-view class="exchange-mark">记绳</cover-view>
        <cover-view class="exchange-sub">翻开纸签</cover-view>
      </cover-view>
    </cover-view>
  </block>

  <view wx:if="{{loading}}" class="floating-note loading-note">正在翻开</view>

  <view wx:if="{{showNote}}" class="modal-mask" catchtouchmove="noop">
    <view class="paper-card note-card">
      <view class="card-title">写成一个结</view>
      <textarea
        class="note-input"
        maxlength="500"
        auto-focus
        value="{{noteText}}"
        placeholder="发生了什么"
        placeholder-class="input-placeholder"
        bindinput="onNoteInput"
      ></textarea>
      <view class="card-actions">
        <button class="text-button" bindtap="closeNote">先不写</button>
        <button class="ink-button" loading="{{saving}}" bindtap="submitKnot">完成</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showDetail}}" class="modal-mask" catchtouchmove="noop">
    <view class="paper-card detail-card">
      <view class="card-title">{{selectedState.title}}</view>
      <view class="card-meta">{{selectedState.meta}}</view>
      <view class="detail-content">{{selectedState.content}}</view>

      <view wx:if="{{selectedState.isResolved}}" class="resolution-lines">
        <view wx:if="{{selectedState.requesterLine}}" class="line-note">{{selectedState.requesterLine}}</view>
        <view wx:if="{{selectedState.accepterLine}}" class="line-note line-note-right">{{selectedState.accepterLine}}</view>
      </view>

      <view wx:if="{{resolveMode}}" class="resolve-form">
        <textarea
          class="resolve-input"
          maxlength="80"
          value="{{resolveText}}"
          placeholder="留一句和解的话"
          placeholder-class="input-placeholder"
          bindinput="onResolveInput"
        ></textarea>
      </view>

      <view class="card-actions">
        <button class="text-button" bindtap="closeDetail">收起</button>
        <button
          wx:if="{{selectedState.canRequest && !resolveMode}}"
          class="ink-button"
          bindtap="openResolveRequest"
        >解开</button>
        <button
          wx:if="{{resolveMode}}"
          class="ink-button"
          loading="{{saving}}"
          bindtap="submitResolve"
        >写好</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showNotebook}}" class="modal-mask" catchtouchmove="noop">
    <view class="paper-card notebook-card">
      <view class="notebook-title-row">
        <view class="card-title">绳本</view>
        <input class="notebook-search" type="text" value="{{notebookSearchText}}" placeholder="搜索" bindinput="onNotebookSearchInput" />
      </view>
      <view class="card-meta">解开的结、留下的印记和印章</view>
      <scroll-view class="notebook-list" scroll-y>
        <block wx:for="{{notebookItems}}" wx:key="id">
          <view class="notebook-item">
            <text class="notebook-item-title">{{item.title}}</text>
            <text class="notebook-item-meta">{{item.meta}}</text>
            <text class="notebook-item-content">{{item.content}}</text>
          </view>
        </block>
      </scroll-view>
      <view class="card-actions">
        <button class="ink-button" bindtap="closeNotebook">收好</button>
      </view>
    </view>
  </view>
</view>
