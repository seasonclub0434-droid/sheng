page {
  min-height: 100%;
  color: #352f2a;
  background: #f5eedf;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

button {
  padding: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  color: inherit;
  line-height: 1.2;
}

button::after {
  border: 0;
}

textarea,
input {
  box-sizing: border-box;
}
